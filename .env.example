# Gmail SMTP (Google App Password required — not your regular Gmail password)
# https://support.google.com/accounts/answer/185833
SMTP_EMAIL=yourgmail@gmail.com
SMTP_PASSWORD=your_google_app_password

# Optional: enable GET /api/contact/test in production (disabled by default)
# ALLOW_SMTP_TEST=true

# Optional: search engine verification (meta tags in layout)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_code
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your_bing_verification_code
